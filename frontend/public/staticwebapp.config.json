{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/images/*.{png,jpg,gif,ico,svg,webp}",
      "/favicon.ico",
      "/icon.png",
      "/*.{json,xml,txt,webmanifest}",
      "/css/*",
      "/js/*"
    ]
  },

  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/index.html",
      "headers": {
        "cache-control": "public, max-age=0, must-revalidate"
      },
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/*",
      "headers": {
        "cache-control": "public, max-age=0, must-revalidate"
      },
      "allowedRoles": ["anonymous"]
    }
  ],

  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },

  "globalHeaders": {
    "content-security-policy": "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; font-src 'self' data: https:; connect-src 'self' https://api.demo.example.org https://login.microsoftonline.com https://graph.microsoft.com https://api.iconify.design https://api.unisvg.com https://api.simplesvg.com;",
    "Cross-Origin-Opener-Policy": "same-origin-allow-popups",
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff"
  },

  "mimeTypes": {
    ".json": "application/json",
    ".js": "application/javascript",
    ".css": "text/css",
    ".html": "text/html"
  }
}
