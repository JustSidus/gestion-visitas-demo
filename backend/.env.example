# =============================================================================
# APLICACIÓN
# =============================================================================
# IMPORTANTE: En Azure, estas variables se generan automáticamente desde
# Application settings en la configuración del App Service

APP_NAME="Institución Demo - Gestión de Visitas"
APP_ENV=local                          # 'local', 'staging', 'production'
APP_KEY=base64:GENERATE_NEW_KEY_WITH_php_artisan_key:generate
APP_DEBUG=true                         # NUNCA true en producción
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
APP_DEMO_MODE=true                     # true solo para entorno demo/local

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# BASE DE DATOS
# =============================================================================
# DESARROLLO: Usar MySQL local o SQLite
# PRODUCCIÓN (Azure): Usar Azure MySQL Flexible Server
# ️ NUNCA incluya contraseñas reales en .env.example

# OPCIÓN 1: MySQL Local (Desarrollo)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=institucion_demo
DB_USERNAME=root
DB_PASSWORD=

# OPCIÓN 2: Azure MySQL (Producción) - Valores de ejemplo, NO REALES
# DB_HOST=mysql-demo.mysql.database.azure.com
# DB_USERNAME=app_user@mysql-demo
# DB_PASSWORD=${DB_PASSWORD}  # Desde Azure App Service settings

# =============================================================================
# BASE DE DATOS - ALERTAS (SISTEMA EXTERNO) - OPCIONAL PARA DEMO
# =============================================================================
# Si no usas el módulo de alertas, puedes omitir estas variables.
ALERTS_DB_HOST=127.0.0.1
ALERTS_DB_PORT=3306
ALERTS_DB_DATABASE=alerts_demo
ALERTS_DB_USERNAME=root
ALERTS_DB_PASSWORD=

# =============================================================================
# CONFIGURACIÓN JWT (JSON Web Tokens)
# =============================================================================
# IMPORTANTE: Generar nueva clave con: php artisan jwt:secret
# ️ CADA AMBIENTE DEBE TENER SU PROPIA JWT_SECRET
# ️ NUNCA compartir entre ambientes
# DESARROLLO: Generar localmente con php artisan jwt:secret
# PRODUCCIÓN: Generar en Azure, guardar como Application setting
JWT_SECRET=

# =============================================================================
# CONFIGURACIÓN DE SESIONES Y CACHE
# =============================================================================
# NOTA: Usamos 'cookie' porque la app es API con JWT
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# CONFIGURACIÓN AZURE AD (Microsoft Authentication)
# =============================================================================
# ️ VALORES SENSIBLES - CONFIGURAR EN AZURE APP SERVICE SETTINGS
# DESARROLLO: Valores de tu tenant de prueba
# PRODUCCIÓN: Valores de tu tenant de producción
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# =============================================================================
# CONFIGURACIÓN DE CORREO
# =============================================================================
# OPCIÓN 1: Log (Para desarrollo - guarda los correos en logs)
MAIL_MAILER=log
MAIL_LOG_CHANNEL=single

# OPCIÓN 2: SMTP Local (Mailtrap, MailHog, etc. para testing)
# MAIL_MAILER=smtp
# MAIL_SCHEME=tls
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=YOUR_MAILTRAP_USERNAME
# MAIL_PASSWORD=YOUR_MAILTRAP_PASSWORD

# OPCIÓN 3: SendGrid (Para producción)
# MAIL_MAILER=sendgrid
# SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY

# OPCIÓN 4: Azure Communication Services (Para producción Azure)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=YOUR_SENDGRID_API_KEY

MAIL_FROM_ADDRESS="noreply@demo.example.org"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# VARIABLES PARA EL FRONTEND (VITE_)
# Estas variables son accesibles desde JavaScript en el navegador
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL=http://localhost:8000/api

# =============================================================================
# NOTAS DE SEGURIDAD Y SETUP
# =============================================================================
# ️  IMPORTANTE:
# 1. Ejecutar después de clonar: php artisan key:generate
# 2. Ejecutar después de clonar: php artisan jwt:secret
# 3. Las variables VITE_ son públicas (visibles en el navegador)
# 4. NUNCA pongas JWT_SECRET, passwords de BD, o API keys privadas en VITE_
# 5. Este archivo DEBE estar en .gitignore en producción
# 6. Para desarrollo: usar SQLite o MySQL local es suficiente
# 7. Para staging/producción: usar Azure MySQL o Azure Communication Services

